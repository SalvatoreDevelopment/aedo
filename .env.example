# Copia questo file in `.env` e compila i valori.
# Il file `.env` NON viene versionato (vedi .gitignore).

# --- Narratore AI (OpenRouter) ---
# Chiave API dal tuo account OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Modello usato come Dungeon Master / cantastorie.
# Default economico e adatto al roleplay (giugno 2026).
AEDO_MODEL=deepseek/deepseek-v4-flash

# --- Bot Discord ---
# Token del bot dalla Discord Developer Portal.
DISCORD_TOKEN=

# --- Database ---
# Percorso del file SQLite (default: data/aedo.db).
AEDO_DB_PATH=data/aedo.db

# --- Memoria narrativa ---
# Modello di embedding locale (scaricato al primo avvio, gratis).
AEDO_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
